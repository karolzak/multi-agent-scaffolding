# Azure AI Foundry Configuration
# Copy this to .env and fill in your actual values

# Azure OpenAI Configuration
AZURE_OPENAI_ENDPOINT=https://your-openai-resource.openai.azure.com/
AZURE_OPENAI_API_KEY=your-api-key-here
AZURE_OPENAI_DEPLOYMENT_NAME=gpt-4o
AZURE_OPENAI_API_VERSION=<VERSION>

# Azure AI Foundry Project
AZURE_AI_PROJECT_CONNECTION_STRING=your-project-connection-string

# Optional: Specific resource group and subscription
AZURE_SUBSCRIPTION_ID=your-subscription-id
AZURE_RESOURCE_GROUP=your-resource-group

# Python path: need to be set to the root of the project
PYTHONPATH=/workspaces/multi-agent-scaffolding